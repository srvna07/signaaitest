# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://signa_user:signa_password@localhost:5433/signa_ai_db"

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ─── Security ─────────────────────────────────────────────────────────────────
# 32-byte encryption key for encrypting secrets (must be 64 hex chars), generated securely and never committed.
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ─── AI Integration ───────────────────────────────────────────────────────────
# Set to 'gemini' or 'groq'
AI_PROVIDER=gemini

# Obtain a free API key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Obtain a free API key from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
