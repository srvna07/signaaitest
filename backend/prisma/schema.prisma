// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  EDITOR
  RUNNER
  VIEWER
}

enum TestCaseType {
  UI
  API
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(VIEWER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects     Project[]
  environments Environment[]
  requirements Requirement[]
  testCases    TestCase[]
  auditLogs    AuditLog[]
  secrets      Secret[]

  @@map("users")
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy   String   @map("created_by")
  creator     User     @relation(fields: [createdBy], references: [id])

  environments Environment[]
  requirements Requirement[]
  testCases    TestCase[]
  secrets      Secret[]

  @@map("projects")
}

model Environment {
  id        String   @id @default(uuid())
  name      String
  baseUrl   String
  variables Json     @default("{}")
  createdAt DateTime @default(now())

  // Auto-login fields
  requiresLogin        Boolean @default(false) @map("requires_login")
  loginPath            String? @map("login_path")
  loginUsernameSecret  String? @map("login_username_secret")
  loginPasswordSecret  String? @map("login_password_secret")

  // Relations
  projectId   String   @map("project_id")
  project     Project  @relation(fields: [projectId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  createdBy   String
  creator     User   @relation(fields: [createdBy], references: [id])
  secrets     Secret[]

  @@map("environments")
}

model Requirement {
  id          String   @id @default(uuid())
  title       String
  description String
  createdAt   DateTime @default(now())

  // Relations
  projectId   String   @map("project_id")
  project     Project  @relation(fields: [projectId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  createdBy   String
  creator   User       @relation(fields: [createdBy], references: [id])
  testCases TestCase[]

  @@map("requirements")
}

model TestCase {
  id             String       @id @default(uuid())
  title          String
  type           TestCaseType
  steps          Json         @default("[]")
  preconditions  String?
  expectedResult String
  // The format of the executable script (e.g. "python-playwright" or "python-requests").
  // Designed as an open string field to allow future extensibility (e.g. "typescript-playwright") without a schema change.
  scriptFormat   String?      @map("script_format")
  scriptContent  String?      @map("script_content")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relations
  projectId     String       @map("project_id")
  project       Project      @relation(fields: [projectId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  requirementId String?
  requirement   Requirement? @relation(fields: [requirementId], references: [id])
  createdBy     String
  creator       User         @relation(fields: [createdBy], references: [id])

  @@index([projectId])
  @@index([requirementId])
  @@index([type])
  @@map("test_cases")
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  entityType String
  entityId   String
  timestamp  DateTime @default(now())

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType])
  @@map("audit_logs")
}

model Secret {
  id              String   @id @default(uuid())
  name            String
  encryptedValue  String   @map("encrypted_value")
  environmentId   String   @map("environment_id")
  projectId       String   @map("project_id")
  createdBy       String   @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  project         Project     @relation(fields: [projectId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  environment     Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  creator         User        @relation(fields: [createdBy], references: [id])

  @@unique([name, environmentId])
  @@index([projectId])
  @@index([environmentId])
  @@map("secrets")
}
